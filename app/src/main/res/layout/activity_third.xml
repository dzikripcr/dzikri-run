<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:backgroundTint="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Home.pertemuan3.ThirdActivity">

  <ImageView
      android:id="@+id/logo"
      android:layout_width="330dp"
      android:layout_height="195dp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toTopOf="parent"
      app:srcCompat="@drawable/sayoor_logo" />

  <TextView
      android:id="@+id/welcome"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="-45dp"
      android:text="Welcome back!"
      android:textColor="@color/welcome"
      android:textSize="28sp"
      android:fontFamily="@font/poppins_semibold"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/logo" />

  <Button
      android:id="@+id/btnFacebook"
      android:layout_width="match_parent"
      android:layout_height="55dp"
      android:layout_marginHorizontal="50dp"
      android:layout_marginTop="20dp"
      android:backgroundTint="@color/facebook"
      android:text="Continue with Facebook"
      android:textColor="@color/white"
      android:textSize="15sp"
      android:fontFamily="@font/poppins_regular"
      app:icon="@drawable/logo_f_facebook"
      app:iconPadding="10dp"
      app:iconSize="22dp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/welcome" />

  <Button
      android:id="@+id/btnGoogle"
      android:layout_width="match_parent"
      android:layout_height="55dp"
      android:layout_marginHorizontal="50dp"
      android:layout_marginTop="5dp"
      android:backgroundTint="@color/white"
      android:text="Continue with Google"
      android:textColor="@color/black"
      android:textSize="15sp"
      android:fontFamily="@font/poppins_light"
      app:icon="@drawable/logo_google"
      app:iconPadding="10dp"
      app:iconSize="22dp"
      app:iconTint="@null"
      app:strokeWidth="1dp"
      app:strokeColor="#E0E0E0"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/btnFacebook"/>

  <TextView
      android:id="@+id/orLogin"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="OR LOGIN WITH USERNAME"
      android:fontFamily="@font/roboto"
      android:layout_marginTop="20dp"
      android:textSize="12sp"
      android:textColor="@color/abu_abu"
      android:textStyle="bold"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/btnGoogle" />

  <EditText
      android:id="@+id/username"
      android:layout_width="match_parent"
      android:layout_height="55dp"
      android:layout_marginHorizontal="50dp"
      android:layout_marginTop="20dp"
      android:inputType="text"
      android:hint="Username..."
      android:textColorHint="@color/abu_abu"
      android:textColor="@color/welcome"
      android:textSize="16sp"
      android:padding="16dp"
      android:background="@drawable/bg_rounded_input"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/orLogin"/>

  <EditText
      android:id="@+id/password"
      android:layout_width="match_parent"
      android:layout_height="55dp"
      android:layout_marginHorizontal="50dp"
      android:layout_marginTop="12dp"
      android:inputType="textPassword"
      android:hint="Password..."
      android:textColorHint="@color/abu_abu"
      android:textColor="@color/welcome"
      android:textSize="16sp"
      android:padding="16dp"
      android:background="@drawable/bg_rounded_input"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/username" />

  <Button
      android:id="@+id/btnLogin"
      android:layout_width="match_parent"
      android:layout_height="55dp"
      android:layout_marginHorizontal="50dp"
      android:layout_marginTop="25dp"
      android:backgroundTint="@color/primary"
      android:fontFamily="@font/poppins_bold"
      android:text="SIGN IN"
      android:textColor="@color/white"
      android:textSize="16sp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/password" />

  <TextView
      android:id="@+id/forgotPW"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginBottom="60dp"
      android:fontFamily="@font/poppins_bold"
      android:text="Forgot password?"
      android:textColor="@color/primary"
      android:textSize="14sp"
      app:layout_constraintBottom_toBottomOf="parent"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent" />

  <TextView
      android:id="@+id/tidakAdaAkun"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginEnd="60dp"
      android:fontFamily="@font/roboto"
      android:text="Don't have an account?"
      android:textColor="@color/abu_abu"
      android:textSize="14sp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/forgotPW" />

  <TextView
      android:id="@+id/signUp"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="-100dp"
      android:fontFamily="@font/poppins_bold"
      android:text="SIGN UP"
      android:textColor="@color/primary"
      android:textSize="14sp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toEndOf="@+id/tidakAdaAkun"
      app:layout_constraintTop_toBottomOf="@+id/forgotPW" />


</androidx.constraintlayout.widget.ConstraintLayout>