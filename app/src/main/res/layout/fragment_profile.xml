<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Profile.ProfileFragment">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:backgroundTint="@color/primary"
        android:background="?attr/colorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="@android:color/white"
        app:subtitleTextColor="@android:color/white" />

    <!-- Scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Main Content -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Judul -->
            <TextView
                android:id="@+id/judul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Profile Pengembang"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:fontFamily="@font/poppins_semibold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Foto -->
            <ImageView
                android:id="@+id/foto_profile"
                android:layout_width="150dp"
                android:layout_height="200dp"
                android:layout_marginTop="20dp"
                android:src="@drawable/foto_profile"
                app:layout_constraintTop_toBottomOf="@id/judul"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Nama -->
            <TextView
                android:id="@+id/nama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Dzikri Maulana"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:fontFamily="@font/poppins_semibold"
                app:layout_constraintTop_toBottomOf="@id/foto_profile"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Role -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/facebook"
                app:cardCornerRadius="12dp"
                app:layout_constraintTop_toBottomOf="@id/nama"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Full Stack Developer"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/poppins_semibold" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Quote -->
            <TextView
                android:id="@+id/quote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginHorizontal="24dp"
                android:gravity="center"
                android:text="“Jangan pernah takut menghadapi masalah, karena dari sanalah kita belajar.”"
                android:textColor="#3F4C6B"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_medium"
                app:layout_constraintTop_toBottomOf="@id/card_role"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Github -->
            <ImageView
                android:id="@+id/github"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_circle_social"
                android:padding="12dp"
                android:src="@drawable/ic_github"
                android:contentDescription="Github"
                app:layout_constraintTop_toBottomOf="@id/quote"
                app:layout_constraintEnd_toStartOf="@id/linkedin"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Linkedin -->
            <ImageView
                android:id="@+id/linkedin"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/bg_circle_social"
                android:padding="12dp"
                android:src="@drawable/ic_linkedin"
                android:contentDescription="Linkedin"
                app:layout_constraintTop_toTopOf="@id/github"
                app:layout_constraintBottom_toBottomOf="@id/github"
                app:layout_constraintStart_toEndOf="@id/github"
                app:layout_constraintEnd_toStartOf="@id/instagram" />

            <!-- Instagram -->
            <ImageView
                android:id="@+id/instagram"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_circle_social"
                android:padding="12dp"
                android:src="@drawable/ic_instagram"
                android:contentDescription="Instagram"
                app:layout_constraintTop_toTopOf="@id/github"
                app:layout_constraintBottom_toBottomOf="@id/github"
                app:layout_constraintStart_toEndOf="@id/linkedin"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Card Tentang -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_tentang"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="20dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/primary"
                app:layout_constraintTop_toBottomOf="@id/github"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/header_tentang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tentang"
                        android:textSize="16sp"
                        android:fontFamily="@font/poppins_semibold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/deskripsi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Saya adalah pengembang aplikasi yang fokus pada pengembangan sistem berbasis web menggunakan Laravel. Terbiasa membangun aplikasi yang rapi, aman, dan scalable."
                        android:textColor="@color/abu_abu"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_regular"
                        app:layout_constraintTop_toBottomOf="@id/header_tentang"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card Skills -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_skills"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/primary"
                app:layout_constraintTop_toBottomOf="@id/card_tentang"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- Header -->
                    <TextView
                        android:id="@+id/header_skill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Skills"
                        android:textSize="16sp"
                        android:fontFamily="@font/poppins_semibold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Laravel -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_laravel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardBackgroundColor="@color/primary"
                        app:cardCornerRadius="12dp"
                        app:layout_constraintTop_toBottomOf="@id/header_skill"
                        app:layout_constraintStart_toStartOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="Laravel"
                            android:textColor="@android:color/white"
                            android:fontFamily="@font/poppins_medium" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- PHP -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_php"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        app:cardBackgroundColor="@color/facebook"
                        app:cardCornerRadius="12dp"
                        app:layout_constraintTop_toTopOf="@id/card_laravel"
                        app:layout_constraintStart_toEndOf="@id/card_laravel">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="PHP"
                            android:textColor="@android:color/white"
                            android:fontFamily="@font/poppins_medium" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- MySQL -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_mysql"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        app:cardBackgroundColor="@color/teal"
                        app:cardCornerRadius="12dp"
                        app:layout_constraintTop_toTopOf="@id/card_laravel"
                        app:layout_constraintStart_toEndOf="@id/card_php">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="MySQL"
                            android:textColor="@android:color/white"
                            android:fontFamily="@font/poppins_medium" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- React JS -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_react"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardBackgroundColor="@color/purple"
                        app:cardCornerRadius="12dp"
                        app:layout_constraintTop_toBottomOf="@id/card_laravel"
                        app:layout_constraintStart_toStartOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="React JS"
                            android:textColor="@android:color/white"
                            android:fontFamily="@font/poppins_medium" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Kotlin -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_kotlin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        app:cardBackgroundColor="@color/design_default_color_secondary"
                        app:cardCornerRadius="12dp"
                        app:layout_constraintTop_toTopOf="@id/card_react"
                        app:layout_constraintStart_toEndOf="@id/card_react">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp"
                            android:text="Kotlin"
                            android:textColor="@android:color/white"
                            android:fontFamily="@font/poppins_medium" />

                    </com.google.android.material.card.MaterialCardView>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>