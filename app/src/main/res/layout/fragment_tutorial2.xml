<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:background="@color/abu_abu"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgTutorial2"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/onboarding2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="180dp"/>

    <TextView
        android:id="@+id/txtTitle2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monitoring Proyek Desa"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="@color/black"
        android:fontFamily="@font/poppins_semibold"
        app:layout_constraintTop_toBottomOf="@id/imgTutorial2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

    <TextView
        android:id="@+id/txtDesc2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Lihat daftar proyek pembangunan yang sedang berjalan beserta informasi pelaksanaan dan progres pengerjaannya."
        android:textAlignment="center"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitle2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>