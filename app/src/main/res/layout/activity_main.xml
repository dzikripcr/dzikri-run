<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- ===== PERSEGI ===== -->
        <TextView
            android:id="@+id/tvJudulPersegi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hitung Luas Persegi"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etSisiPersegi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Masukkan sisi"
            android:inputType="numberDecimal"
            app:layout_constraintTop_toBottomOf="@id/tvJudulPersegi"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnHitungPersegi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Hitung Luas"
            app:layout_constraintTop_toBottomOf="@id/etSisiPersegi"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvHasilPersegi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hasil: "
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/btnHitungPersegi"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- ===== KUBUS ===== -->
        <TextView
            android:id="@+id/tvJudulKubus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hitung Volume Kubus"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tvHasilPersegi"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/etSisiKubus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Masukkan sisi"
            android:inputType="numberDecimal"
            app:layout_constraintTop_toBottomOf="@id/tvJudulKubus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnHitungKubus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Hitung Volume"
            app:layout_constraintTop_toBottomOf="@id/etSisiKubus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvHasilKubus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hasil: "
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/btnHitungKubus"
            app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>