<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:background="@color/abu_abu"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgTutorial3"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/onboarding3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="180dp"/>

    <TextView
        android:id="@+id/txtTitle3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Informasi Lengkap Proyek"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="@color/black"
        android:fontFamily="@font/poppins_semibold"
        app:layout_constraintTop_toBottomOf="@id/imgTutorial3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

    <TextView
        android:id="@+id/txtDesc3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ketahui lokasi proyek, kontraktor pelaksana, dan informasi pembangunan desa secara lengkap dan transparan."
        android:textAlignment="center"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitle3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnMulai"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="60dp"
        android:layout_marginBottom="40dp"
        android:backgroundTint="@color/primary"
        android:text="Ayo Mulai"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtDesc3" />

</androidx.constraintlayout.widget.ConstraintLayout>